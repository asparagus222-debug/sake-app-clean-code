
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userEditableKeys() {
      return [
        'id',
        'accountType',
        'username',
        'bio',
        'avatarUrl',
        'instagram',
        'twitter',
        'facebook',
        'threads',
        'website',
        'qualifications',
        'hasPin',
        'isAccountDeleted',
        'deletedAt',
        'themeSettings',
        'updatedAt',
        'createdAt'
      ];
    }

    function validInitialNoteSocialState() {
      return (!request.resource.data.keys().hasAny(['likesCount']) || request.resource.data.likesCount == 0)
        && (!request.resource.data.keys().hasAny(['likedByUserIds']) || request.resource.data.likedByUserIds.size() == 0);
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isAdmin() || (
        isOwner(userId)
        && request.resource.data.id == userId
        && request.resource.data.keys().hasOnly(userEditableKeys())
      );
      allow update: if isAdmin() || (
        isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userEditableKeys())
      );
      allow delete: if isAdmin();

      match /followers/{followerId} {
        allow read: if true;
        allow create, update, delete: if isAdmin() || isOwner(userId);
      }

      match /following/{followingId} {
        allow read: if true;
        allow create, update, delete: if isAdmin() || isOwner(userId);
      }
    }

    match /sakeTastingNotes/{noteId} {
      allow read: if true;
      allow create: if isAdmin() || (
        isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && validInitialNoteSocialState()
      );
      allow update: if isAdmin() || (
        isSignedIn()
        && resource.data.userId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['likedByUserIds', 'likesCount'])
      );
      allow delete: if isAdmin() || (
        isSignedIn()
        && resource.data.userId == request.auth.uid
      );

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAdmin() || (
          isSignedIn()
          && request.resource.data.userId == request.auth.uid
        );
        allow update, delete: if isAdmin() || (
          isSignedIn()
          && resource.data.userId == request.auth.uid
        );
      }
    }

    match /reports/{reportId} {
      allow create: if isAdmin() || (
        isSignedIn()
        && request.resource.data.userId == request.auth.uid
      );
      allow read, update, delete: if isAdmin();
    }

    match /breweryIntros/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /breweryIntroRequests/{docId} {
      allow read, update, delete: if isAdmin();
      allow create: if false;
    }

    match /meta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sponsorPayments/{docId} {
      allow read, write: if isAdmin();
    }

    match /notes/{noteId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
