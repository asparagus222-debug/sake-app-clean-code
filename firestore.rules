
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && (request.auth.uid == uid || request.auth.token.sub == uid);
    }

    // 允許已登入用戶讀寫所有資料
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /sakeTastingNotes/{noteId} {
      allow read, write: if isSignedIn();
    }

    match /notes/{noteId} {
      allow read, write: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
