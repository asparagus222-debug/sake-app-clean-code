# 複製為 .env.local 後填入（勿將含真值的檔案提交至 Git）
# Next.js 會自動載入：.env.local > .env.development > .env

# ── Google AI（Gemini）────────────────────────────────────────────
# 多數 /api/ai/* 路由與 Genkit（酒造摘要、酒標辨識主流程等）需要。
# 請至 Google AI Studio / Vertex 建立 API 金鑰。
GEMINI_API_KEY=

# ── Cloud Vision API ────────────────────────────────────────────────
# 酒標辨識流程（identify-sake）的 OCR / WEB_DETECTION；無則該段預檢可能為空。
GOOGLE_CLOUD_VISION_API_KEY=

# 備用：vision-web-detect 路由會嘗試 GEMINI / GOOGLE_API_KEY
# GOOGLE_API_KEY=

# ── Firebase App Check（可選）──────────────────────────────────────
# 設為 true 時，受保護的 API 會要求標頭 X-Firebase-AppCheck。
# 本機開發通常維持未設定或 false，避免未設定 reCAPTCHA 時無法呼叫。
# FIREBASE_APP_CHECK_ENFORCED=true

# reCAPTCHA v3 Site Key（前端 App Check；需與 Console 中 App Check 設定一致）
NEXT_PUBLIC_RECAPTCHA_V3_SITE_KEY=

# ── 公開網址（贊助／付款回調）──────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:9002

# ── 綠界 ECPay（贊助功能）────────────────────────────────────────────
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
# 未設或為 true 時走測試環（依程式邏輯）；正式上線設 false 並改用正式商店參數
ECPAY_IS_TEST=true

# ── Firebase Admin（本機指令碼與部分伺服端情境）─────────────────────
# 擇一即可：服務帳戶 JSON 檔路徑，或整段 JSON 字串（適合雲端／CI）
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# ── Genkit 選用：Anthropic 外掛已註冊；若未使用 Claude 模型可略 ───────
# ANTHROPIC_API_KEY=
